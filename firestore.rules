rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      
      // Allow users to update their own profile stats, quests, badges, level and details.
      allow update: if isOwner(userId);
        
      allow delete: if false;
      
      // User Subcollections
      match /activities/{activityId} {
        allow read, write: if isOwner(userId);
      }
      
      match /reports/{reportId} {
        allow read: if isOwner(userId);
        allow write: if false; 
      }
      
      match /badges/{badgeId} {
        allow read: if isSignedIn(); 
        allow write: if false; 
      }
      
      match /notifications/{notificationId} {
        allow read: if isOwner(userId);
        allow update: if isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
        allow delete: if isOwner(userId);
      }
    }

    // Challenges Collection
    match /challenges/{challengeId} {
      allow read: if isSignedIn();
      allow write: if false; 
      
      match /participants/{participantUserId} {
        allow read: if isSignedIn();
        allow write: if isOwner(participantUserId);
      }
    }

    // System Badges (Static Catalog)
    match /system_badges/{badgeId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Leaderboards Cache
    match /leaderboards/{leaderboardId} {
      allow read: if isSignedIn();
      allow write: if false; 
    }
  }
}
